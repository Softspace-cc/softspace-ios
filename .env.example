# Copy to .env and fill in real values for production deployment.

# Postgres
POSTGRES_USER=softspace
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=softspace

# Server
JWT_SECRET=change-me-to-a-long-random-string-min-64-chars
CLIENT_ORIGIN=https://softspace.cc
MAX_UPLOAD_MB=25

# Client (baked in at build time)
VITE_API_URL=https://softspace.cc/api
VITE_SOCKET_URL=https://softspace.cc

# Domain for nginx / certbot
DOMAIN=softspace.cc
ACME_EMAIL=admin@softspace.cc
