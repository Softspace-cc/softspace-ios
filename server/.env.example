# Database Configuration
# PostgreSQL is recommended for production. SQLite works for local dev.
DATABASE_URL="postgresql://user:pass@localhost:5432/softspace"
# For SQLite, use: DATABASE_URL="file:./dev.db"

# Server Configuration
PORT=4000
NODE_ENV="development"

# Security
# Set a strong, random 32+ character string for JWT_SECRET
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# CORS Configuration
# Comma-separated list of allowed origins. Use * for development.
CLIENT_ORIGIN="http://localhost:5173"

# Uploads Configuration
# Directory where files will be stored. Defaults to ./uploads
UPLOAD_DIR="./uploads"
# Desktop release payloads (SoftSpace-x.y.z.zip)
RELEASES_DIR="./releases"

# Status page admin (api.softspace.cc → Admin panel)
STATUS_ADMIN_PASSWORD="change-me-to-a-strong-password"
# Optional: URL checked for web-app health (default https://softspace.cc)
# STATUS_WEB_URL="https://softspace.cc"
# STATUS_CHECK_INTERVAL_MS=60000
# Max upload size in megabytes
MAX_UPLOAD_MB=25

# Email Configuration (Strato SMTP Example)
SMTP_HOST="smtp.strato.de"
SMTP_PORT=465
SMTP_SECURE="true"
SMTP_USER="no-reply@softspace.cc"
SMTP_PASS="J4m!e2025#Go"

# Discord OAuth
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"
DISCORD_REDIRECT_URI="http://localhost:5173/auth/discord/callback"

# Telegram Login
TELEGRAM_BOT_NAME="your_bot_username"
TELEGRAM_BOT_TOKEN="your_bot_token"